@{
    ViewData["Title"] = "Home";
}

<div id="employees-loading">Loading...</div>

<div id="empty-state" class="d-none">
    <p>No employees have been created yet.</p>
    <a href="/Employees/Create" class="btn btn-primary">Create employee</a>
</div>

<div id="employees-section" class="d-none">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Employees</h2>
        <a href="/Employees/Create" class="btn btn-primary">Create employee</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>First name</th>
                <th>Last name</th>
                <th>Type</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody id="employees-tbody">
        </tbody>
    </table>

    <div id="pagination-container" class="pagination justify-content-center">
    </div>
</div>

@section Scripts {
    <script src="~/js/employees-table.js"></script>
}
